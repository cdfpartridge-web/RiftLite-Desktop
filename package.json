{
  "name": "riftlite-desktop-v09",
  "version": "0.9.0",
  "private": true,
  "description": "RiftLite 0.9 desktop companion app.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "cards:registry:update": "node scripts/update-riftbound-registry.mjs",
    "cards:registry:check": "node scripts/update-riftbound-registry.mjs --dry-run",
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "cross-env NODE_ENV=development concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "electron:smoke": "npm run build:electron && cross-env NODE_ENV=development concurrently -k -s first \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron . --riftlite-smoke-test\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:game-preload": "esbuild src/game-preload/gamePreload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/game-preload/gamePreload.cjs",
    "build": "npm run build:electron && npm run build:game-preload && vite build",
    "release:account-sync-gate": "vitest run tests/accountCloudSync.test.ts tests/accountCloudSyncQueue.test.ts tests/accountCloudRestoreCoordinator.test.ts tests/accountIdentity.test.ts tests/accountSyncConfidence.test.ts",
    "release:gate": "npm run lint && npm run release:account-sync-gate && npm test",
    "electron:build": "npm run release:gate && npm run build && electron-builder --win nsis --publish never",
    "electron:build:mac": "npm run release:gate && npm run build && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.1.3",
    "date-fns": "^4.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.556.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sql.js": "^1.14.1",
    "vite": "^7.2.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.riftlite.desktop.beta06",
    "productName": "RiftLite Beta 0.9",
    "protocols": [
      {
        "name": "RiftLite",
        "schemes": [
          "riftlite"
        ]
      }
    ],
    "executableName": "RiftLite Beta 0.9",
    "artifactName": "RiftLiteBetaInstall.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "cdfpartridge-web",
        "repo": "RiftLite-Desktop"
      }
    ],
    "directories": {
      "output": "release"
    },
    "afterPack": "build/afterPack.cjs",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/riftlite-app.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "identity": "-",
      "artifactName": "RiftLiteBetaInstall-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "RiftLite Beta 0.9",
      "uninstallDisplayName": "RiftLite Beta 0.9"
    }
  }
}
